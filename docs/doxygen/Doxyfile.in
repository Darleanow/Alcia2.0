PROJECT_NAME           = "Alcia"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "A text-based RPG built with Qt 6"
PROJECT_LOGO           = @CMAKE_SOURCE_DIR@/docs/assets/logo.png

OUTPUT_DIRECTORY       = @CMAKE_BINARY_DIR@
CREATE_SUBDIRS         = YES
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

INPUT                  = @CMAKE_SOURCE_DIR@/include \
                         @CMAKE_SOURCE_DIR@/src \
                         @CMAKE_SOURCE_DIR@/README.md
FILE_PATTERNS          = *.hpp *.h *.cpp *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */tests/fuzz/*
USE_MDFILE_AS_MAINPAGE = @CMAKE_SOURCE_DIR@/README.md

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_EXTRA_STYLESHEET  = @CMAKE_SOURCE_DIR@/docs/doxygen/doxygen-awesome.css \
                         @CMAKE_SOURCE_DIR@/docs/doxygen/doxygen-awesome-sidebar-only.css \
                         @CMAKE_SOURCE_DIR@/docs/doxygen/custom.css
HTML_EXTRA_FILES       = @CMAKE_SOURCE_DIR@/docs/doxygen/doxygen-awesome-darkmode-toggle.js \
                         @CMAKE_SOURCE_DIR@/docs/doxygen/doxygen-awesome-fragment-copy-button.js \
                         @CMAKE_SOURCE_DIR@/docs/doxygen/doxygen-awesome-paragraph-link.js \
                         @CMAKE_SOURCE_DIR@/docs/doxygen/doxygen-awesome-interactive-toc.js
HTML_HEADER            = @CMAKE_SOURCE_DIR@/docs/doxygen/header.html
HTML_FOOTER            = @CMAKE_SOURCE_DIR@/docs/doxygen/footer.html
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
DISABLE_INDEX          = NO
HTML_COLORSTYLE        = AUTO_LIGHT

HAVE_DOT               = YES
DOT_NUM_THREADS        = 4
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO
